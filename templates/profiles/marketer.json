{
  "id": "marketer",
  "label": "Marketinges",
  "description": "Email-vázlat, hírlevél, social tartalom. Mivel webes tartalmat olvas (prompt injection felület), szigorúan korlátozott: csak a saját mappájába írhat, SSH/AWS/.env tiltva, semmilyen Bash-pusztító parancs.",
  "permissionMode": "strict",
  "filesystem": {
    "allow": [
      "Read(${AGENT_DIR}/**)",
      "Write(${AGENT_DIR}/**)",
      "Edit(${AGENT_DIR}/**)",
      "Read(${HOME}/Downloads/**)",
      "Read(${HOME}/localdev/marveen/**)",
      "Write(${HOME}/localdev/marveen/prototypes/**)",
      "Edit(${HOME}/localdev/marveen/prototypes/**)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(date:*)",
      "Bash(sqlite3:*)",
      "Bash(mkdir:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(python3:*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__plugin_context-mode_context-mode__ctx_fetch_and_index",
      "mcp__plugin_context-mode_context-mode__ctx_search",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_index"
    ],
    "deny": [
      "Read(${HOME}/.ssh/**)",
      "Read(${HOME}/.aws/**)",
      "Read(${HOME}/.gnupg/**)",
      "Read(${HOME}/.env)",
      "Read(**/.env)",
      "Bash(sudo:*)",
      "Bash(rm:*)"
    ]
  }
}
