{
  "id": "researcher",
  "label": "Kutató",
  "description": "Piackutatás, versenytárs-elemzés, webes források olvasása. Prompt injection szempontból ugyanúgy kiemelt mint a marketinges. Draft-only: riportot ír a mappájába, nem küld magától kifelé.",
  "permissionMode": "strict",
  "filesystem": {
    "allow": [
      "Read(${AGENT_DIR}/**)",
      "Write(${AGENT_DIR}/**)",
      "Edit(${AGENT_DIR}/**)",
      "Read(${HOME}/Downloads/**)",
      "Read(${HOME}/localdev/marveen/**)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(date:*)",
      "Bash(mkdir:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(echo:*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__plugin_context-mode_context-mode__ctx_fetch_and_index",
      "mcp__plugin_context-mode_context-mode__ctx_search",
      "mcp__plugin_context-mode_context-mode__ctx_index"
    ],
    "deny": [
      "Read(${HOME}/.ssh/**)",
      "Read(${HOME}/.aws/**)",
      "Read(${HOME}/.gnupg/**)",
      "Read(${HOME}/.env)",
      "Read(**/.env)",
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(git push:*)",
      "Bash(curl -X POST:*)"
    ]
  }
}
